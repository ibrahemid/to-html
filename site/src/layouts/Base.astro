---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'to-html', description = 'Render agent output as self-contained HTML artifacts.' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const rootUrl = baseUrl.replace(/\/$/, '') || '/';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap">
  <title>{title}</title>
  <style is:global>
    :root {
      --paper: #fbfaf6;
      --paper-tint: #f1f0eb;
      --paper-sunk: #ede9df;
      --ink: #15151a;
      --ink-strong: #000;
      --ink-muted: #555560;
      --ink-faint: #6f6f78;
      --ink-trace: #d4d0c8;
      --rule: #e4e2dc;
      --rule-strong: #d0cdc4;
      --accent: #4a37c8;
      --accent-deep: #3a2ca8;
      --accent-soft: rgba(74, 55, 200, 0.08);
      --accent-line: rgba(74, 55, 200, 0.24);
      --terminal-bg: #0c0c0d;
      --terminal-fg: #ededed;
      --terminal-prompt: #a99bff;
      --sans: "IBM Plex Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, system-ui, sans-serif;
      --mono: "IBM Plex Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --paper: #0e0e10;
        --paper-tint: #17171a;
        --paper-sunk: #1a1a1f;
        --ink: #e8e8ee;
        --ink-strong: #fafafa;
        --ink-muted: #b3b3bb;
        --ink-faint: #9e9ea6;
        --ink-trace: #2a2a2f;
        --rule: #26262b;
        --rule-strong: #3a3a40;
        --accent: #a99bff;
        --accent-deep: #c4bbff;
        --accent-soft: rgba(169, 155, 255, 0.12);
        --accent-line: rgba(169, 155, 255, 0.30);
        --terminal-bg: #17171a;
        --terminal-fg: #e8e8ee;
      }
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    html, body {
      margin: 0; padding: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      font-feature-settings: "kern", "liga", "tnum", "ss01";
    }
    ::selection { background: var(--accent-soft); color: var(--ink); }
    a {
      color: var(--ink);
      text-decoration: none;
      border-bottom: 1px solid var(--accent);
      transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
    }
    a:hover { color: var(--accent); }
    a:focus-visible,
    button:focus-visible,
    input:focus-visible,
    [tabindex]:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      border-radius: 2px;
    }
    code, kbd, samp { font-family: var(--mono); font-variant-ligatures: none; }
    code {
      font-size: 0.84em;
      background: var(--paper-sunk);
      padding: 1px 6px;
      border-radius: 3px;
      color: var(--ink);
      border: 1px solid var(--rule);
    }
    pre {
      background: var(--terminal-bg);
      color: var(--terminal-fg);
      padding: 18px 20px;
      overflow-x: auto;
      font-size: 0.78rem;
      line-height: 1.7;
      border-radius: 4px;
      border: 1px solid var(--rule-strong);
      margin: 0;
      font-feature-settings: "ss01";
    }
    pre code {
      background: transparent;
      color: inherit;
      padding: 0;
      border: 0;
      font-size: inherit;
    }
    hr { border: none; border-top: 1px solid var(--rule); margin: 56px 0; }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 24px 40px 80px;
    }
    .masthead {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 0;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 80px;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
    .masthead .left { display: flex; gap: 6px; align-items: center; color: var(--ink-muted); }
    .masthead .nameplate {
      font-family: var(--mono);
      font-weight: 600;
      color: var(--ink);
      letter-spacing: 0;
    }
    .masthead .slash { color: var(--ink-faint); padding: 0 4px; }
    .masthead .ver { color: var(--ink-muted); }
    .masthead nav { display: flex; gap: 18px; }
    .masthead nav a {
      border-bottom: none;
      color: var(--ink-muted);
      font-family: var(--mono);
      letter-spacing: 0.02em;
    }
    .masthead nav a:hover { color: var(--accent); }

    .section-label {
      display: grid;
      grid-template-columns: max-content 1fr;
      align-items: center;
      gap: 18px;
      margin: 80px 0 32px;
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-muted);
    }
    .section-label::after {
      content: "";
      border-top: 1px solid var(--rule);
      display: block;
    }

    .colophon {
      margin-top: 96px;
      padding-top: 16px;
      border-top: 1px solid var(--rule);
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--ink-faint);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .colophon a { border-bottom: none; color: var(--ink-muted); }
    .colophon a:hover { color: var(--accent); }

    @media (max-width: 720px) {
      .page { padding: 16px 22px 64px; }
      .masthead { flex-direction: column; gap: 10px; align-items: flex-start; margin-bottom: 48px; }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="masthead">
      <div class="left">
        <span class="nameplate"><a href={rootUrl} style="border-bottom:none;color:var(--ink);">ibrahemid/to-html</a></span>
        <span class="slash">·</span>
        <span class="ver">MIT · Node</span>
      </div>
      <nav>
        <a href={rootUrl}>index</a>
        <a href="https://github.com/ibrahemid/to-html">source</a>
        <a href="https://github.com/ibrahemid/to-html/blob/main/adapters/claude-code/CHANGELOG.md">changelog</a>
        <a href="https://github.com/ibrahemid/to-html/issues">issues</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer class="colophon">
      <span>MIT</span>
      <span>{new Date().getUTCFullYear()}</span>
    </footer>
  </div>
</body>
</html>
