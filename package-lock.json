{
  "name": "to-html-monorepo",
  "version": "2.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "to-html-monorepo",
      "version": "2.1.0",
      "workspaces": [
        "core",
        "cli",
        "shared/transcript",
        "adapters/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "adapters/claude-code": {
      "name": "to-html",
      "version": "2.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "cli": {
      "name": "@ibrahemid/to-html",
      "version": "2.1.0",
      "bin": {
        "to-html": "bin/to-html.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "core": {
      "name": "@ibrahemid/to-html-core",
      "version": "2.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@ibrahemid/to-html": {
      "resolved": "cli",
      "link": true
    },
    "node_modules/@ibrahemid/to-html-core": {
      "resolved": "core",
      "link": true
    },
    "node_modules/@ibrahemid/to-html-shared-transcript": {
      "resolved": "shared/transcript",
      "link": true
    },
    "node_modules/to-html": {
      "resolved": "adapters/claude-code",
      "link": true
    },
    "shared/transcript": {
      "name": "@ibrahemid/to-html-shared-transcript",
      "version": "2.1.0",
      "engines": {
        "node": ">=18"
      }
    }
  }
}
